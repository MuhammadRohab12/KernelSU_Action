# =========================================
# Stormbreaker Kernel - Redmi S2 (ysl)
# KernelSU Build Config
# Android 12 | AOSP Clang
# =========================================

# -- Kernel Source --
KERNEL_SOURCE=https://github.com/stormbreaker-project/kernel_xiaomi_ysl
KERNEL_SOURCE_BRANCH=main
KERNEL_CONFIG=vendor/ysl_defconfig
KERNEL_IMAGE_NAME=Image.gz-dtb
ARCH=arm64

# -- Clang (AOSP default) --
USE_CUSTOM_CLANG=false
CLANG_BRANCH=master-kernel-build-2022
CLANG_VERSION=r450784e

# -- GCC (needed alongside Clang for arm32 compat) --
ENABLE_GCC_ARM64=true
ENABLE_GCC_ARM32=true
USE_CUSTOM_GCC_64=false
USE_CUSTOM_GCC_32=false

# -- KernelSU --
ENABLE_KERNELSU=true
KERNELSU_TAG=v0.9.5
# Use kprobes method (safer for ysl kernel 4.9)
ADD_KPROBES_CONFIG=true
APPLY_KSU_PATCH=false

# -- Kernel Config Extras --
ADD_OVERLAYFS_CONFIG=true
DISABLE-LTO=false
DISABLE_CC_WERROR=false
ADD_LOCALVERSION_TO_FILENAME=false

# -- AnyKernel3 --
USE_CUSTOM_ANYKERNEL3=false

# -- Output --
NEED_DTBO=true
BUILD_BOOT_IMG=false
SOURCE_BOOT_IMAGE=

# -- Build Speed --
ENABLE_CCACHE=true
REMOVE_UNUSED_PACKAGES=true

# -- Extra make args (leave blank if unsure) --
EXTRA_CMDS=
CUSTOM_CMDS=LLVM=1 LLVM_IAS=1

# -- KSU verification (optional, leave blank) --
KSU_EXPECTED_SIZE=
KSU_EXPECTED_HASH=
